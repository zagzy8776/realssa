# RealSSA News - Environment Variables
# Copy this file to .env and fill in your actual values

# ============================================
# CRON JOB SECRET (Required for cron-job.org)
# Must match the ?secret= param in your cron-job.org URLs
# ============================================
CRON_SECRET=realssa-cron-secret-2026

# ============================================
# BACKEND/API CONFIGURATION (Required)
# ============================================
# JWT Secret for authentication (use a strong random string)
JWT_SECRET=your_secure_random_jwt_secret_here_minimum_32_characters

# API URLs (for local development)
VITE_API_URL=http://localhost:5000
VITE_BACKEND_URL=http://localhost:5000

# ============================================
# ONESIGNAL PUSH NOTIFICATIONS (Active)
# Already configured in index.html with App ID: 055b6596-a96c-48e2-8cda-ff4bb6d61009
# This is your PRIMARY notification system
# ============================================
VITE_ONESIGNAL_APP_ID=055b6596-a96c-48e2-8cda-ff4bb6d61009

# ============================================
# FIREBASE (OPTIONAL - Not Currently Used)
# Only needed if you want to add FCM as backup notification system
# You are using OneSignal only, so Firebase is NOT required
# ============================================
# FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"your-project"}
# Or use individual environment variables:
# FIREBASE_TYPE=service_account
# FIREBASE_PROJECT_ID=your-project-id
# FIREBASE_PRIVATE_KEY_ID=your-private-key-id
# FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
# FIREBASE_CLIENT_EMAIL=firebase-adminsdk@your-project.iam.gserviceaccount.com
# FIREBASE_CLIENT_ID=123456789012345678901
# FIREBASE_AUTH_URI=https://accounts.google.com/o/oauth2/auth
# FIREBASE_TOKEN_URI=https://oauth2.googleapis.com/token
# FIREBASE_AUTH_PROVIDER_CERT_URL=https://www.googleapis.com/oauth2/v1/certs
# FIREBASE_CLIENT_CERT_URL=https://www.googleapis.com/robot/v1/metadata/x509/...

# ============================================
# YOUTUBE API (Optional - for video content)
# Get from: https://console.cloud.google.com
# ============================================
VITE_YOUTUBE_API_KEY=your_youtube_api_key_here

# ============================================
# GOOGLE GENERATIVE AI (Optional - for AI features)
# ============================================
GOOGLE_GENERATIVE_AI_API_KEY=your_google_ai_key_here

# ============================================
# FOOTBALL DATA API (Optional - for live sports)
# ============================================
FOOTBALL_DATA_API_KEY=your_football_data_api_key_here

# ============================================
# DATABASE (PostgreSQL/Neon - Optional)
# Only needed if you want to use a database instead of JSON files
# ============================================
DATABASE_URL=postgresql://username:password@host:5432/database
PGHOST=your-postgres-host.neon.tech
PGDATABASE=your-database-name
PGUSER=your-username
PGPASSWORD=your-password

# ============================================
# DEPLOYMENT (Vercel - automatically set by Vercel)
# ============================================
# These are set automatically by Vercel, no need to configure
# VERCEL=1
# VERCEL_ENV=production
# VERCEL_URL=your-site.vercel.app

# ============================================
# FLY.IO BACKEND URL
# Set this so services like matchMapper / crawlerService can call the Fly.io sports scores endpoint
# ============================================
SCORES_API_URL=https://realssa-scraper.fly.dev

# ============================================
# BUFFER SOCIAL MEDIA INTEGRATION (Optional)
# Automates posting of new articles to connected social profiles
# Set these in Fly.io secrets: fly secrets set BUFFER_ACCESS_TOKEN=... BUFFER_PROFILE_IDS=...
# ============================================
BUFFER_ACCESS_TOKEN=your_buffer_access_token_here
BUFFER_PROFILE_IDS=profile_id_1,profile_id_2
